# 릴리스 서명 설정 예시. 이 파일을 복사해 android/keystore.properties 로 만들고
# 실제 값을 채운 뒤 저장하세요. (keystore.properties 는 .gitignore로 커밋 제외됨)
#
# 1) 업로드 키스토어 생성(한 번만, 안전하게 백업 — 분실 시 앱 업데이트 영구 불가):
#    keytool -genkeypair -v -keystore android/app/upload-keystore.jks \
#      -alias upload -keyalg RSA -keysize 2048 -validity 10000
#    (Windows PowerShell에서도 동일. keytool은 JDK에 포함)
#
# 2) 아래 값을 실제로 채우기:
#    - storeFile: android/app 기준 상대경로(위 예시대로면 upload-keystore.jks)
#    - storePassword / keyPassword: 생성 시 입력한 비밀번호
#    - keyAlias: 생성 시 지정한 alias(위 예시는 upload)

storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
