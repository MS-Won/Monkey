# Monkey 프로젝트 환경변수 예시
# 이 파일을 복사해 `.env` 로 만들고 실제 값을 채우세요. (`.env` 는 절대 커밋 금지 — .gitignore로 제외됨)

# OpenAI API 키 (백엔드 해몽/분리/임베딩 호출용) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# 백엔드(Flask) 주소. Android 에뮬레이터에서 PC 로컬 백엔드는 10.0.2.2 로 접근.
SERVER_BASE_URL=http://10.0.2.2:5001
